---
import Layout from "../components/Layout.astro";
import MovieTable from "../components/MovieTable.astro";

export const prerender = true;
---

<Layout title="Movie Night">
  <section class="frontpage">
    <p class="intro-eyebrow">Kaohsiung Movie Night</p>
    <p class="intro-sub" data-subtitle>
      Development in progress, please come back later my fren
    </p>
    <MovieTable />
  </section>
</Layout>

<style>
  @import url("https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap");

  :global(body) {
    margin: 0;
    min-height: 100vh;
    background: linear-gradient(180deg, #300842 0%, #1b2050 50%, #0b2d55 100%);
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  :global(main) {
    width: 100%;
  }

  .frontpage {
    font-family: "VT323", "Courier New", monospace;
    color: #fefbf5;
    padding: 2.5rem 0 4rem;
    text-align: center;
  }

  .intro-eyebrow {
    font-family: "Press Start 2P", "Courier New", monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #f7f06b;
    margin: 0;
  }

  .intro-sub {
    font-size: 1.2rem;
    color: #f1e8d5;
    font-weight: 400;
    margin: 0.75rem auto 0;
  }
</style>
