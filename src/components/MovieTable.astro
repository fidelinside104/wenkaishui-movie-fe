---
// Client-side island
---

<div class="records" data-component="movie-table">
  <div class="records-controls" data-controls hidden>
    <div class="control">
      <label class="control-label" for="include-past">Include past</label>
      <select id="include-past" class="control-input" data-include-past>
        <option value="yes">Yes</option>
        <option value="no" selected>No</option>
      </select>
    </div>
    <div class="control">
      <span class="control-label">Cinemas</span>
      <details class="multi-select" data-cinema-dropdown>
        <summary class="multi-select-summary" data-cinema-summary>All cinemas</summary>
        <div class="multi-select-panel">
          <div class="multi-select-actions">
            <button type="button" class="ghost-button" data-select-all>Select all</button>
            <button type="button" class="ghost-button" data-deselect-all>Deselect all</button>
          </div>
          <div class="multi-select-options" data-cinema-options></div>
        </div>
      </details>
    </div>
    <div class="control">
      <span class="control-label">Movies</span>
      <details class="multi-select" data-movie-dropdown>
        <summary class="multi-select-summary" data-movie-summary>All movies</summary>
        <div class="multi-select-panel">
          <input
            type="text"
            class="multi-select-search"
            data-movie-search
            placeholder="Search movies"
          />
          <div class="multi-select-actions">
            <button type="button" class="ghost-button" data-movie-select-all>Select all</button>
            <button type="button" class="ghost-button" data-movie-deselect-all>Deselect all</button>
          </div>
          <div class="multi-select-options" data-movie-options></div>
        </div>
      </details>
    </div>
    <div class="control">
      <span class="control-label">Genres</span>
      <details class="multi-select" data-genre-dropdown>
        <summary class="multi-select-summary" data-genre-summary>All genres</summary>
        <div class="multi-select-panel">
          <div class="multi-select-actions">
            <button type="button" class="ghost-button" data-genre-select-all>Select all</button>
            <button type="button" class="ghost-button" data-genre-deselect-all>Deselect all</button>
          </div>
          <div class="multi-select-options" data-genre-options></div>
        </div>
      </details>
    </div>
  </div>

  <p class="records-status" data-status>Loading screenings...</p>
  <div class="records-table" data-table hidden>
    <table class="movie-table">
      <thead>
        <tr>
          <th>Time</th>
          <th>Cinema</th>
          <th>Movie</th>
        </tr>
      </thead>
      <tbody data-rows></tbody>
    </table>
  </div>
</div>

<script>
  import { createClient } from "@supabase/supabase-js";

  const root = document.querySelector('[data-component="movie-table"]');
  if (!root) {
    throw new Error("MovieTable root not found");
  }

  const statusEl = root.querySelector("[data-status]") as HTMLElement | null;
  const tableWrap = root.querySelector("[data-table]") as HTMLElement | null;
  const rowsEl = root.querySelector("[data-rows]") as HTMLElement | null;
  const controlsEl = root.querySelector("[data-controls]") as HTMLElement | null;
  const includePastEl = root.querySelector(
    "[data-include-past]"
  ) as HTMLSelectElement | null;
  const cinemaOptionsEl = root.querySelector("[data-cinema-options]") as HTMLElement | null;
  const cinemaSummaryEl = root.querySelector("[data-cinema-summary]") as HTMLElement | null;
  const cinemaDropdownEl = root.querySelector(
    "[data-cinema-dropdown]"
  ) as HTMLDetailsElement | null;
  const selectAllBtn = root.querySelector("[data-select-all]") as HTMLButtonElement | null;
  const deselectAllBtn = root.querySelector("[data-deselect-all]") as HTMLButtonElement | null;
  const movieOptionsEl = root.querySelector("[data-movie-options]") as HTMLElement | null;
  const movieSummaryEl = root.querySelector("[data-movie-summary]") as HTMLElement | null;
  const movieDropdownEl = root.querySelector(
    "[data-movie-dropdown]"
  ) as HTMLDetailsElement | null;
  const movieSearchEl = root.querySelector(
    "[data-movie-search]"
  ) as HTMLInputElement | null;
  const movieSelectAllBtn = root.querySelector(
    "[data-movie-select-all]"
  ) as HTMLButtonElement | null;
  const movieDeselectAllBtn = root.querySelector(
    "[data-movie-deselect-all]"
  ) as HTMLButtonElement | null;
  const genreOptionsEl = root.querySelector("[data-genre-options]") as HTMLElement | null;
  const genreSummaryEl = root.querySelector("[data-genre-summary]") as HTMLElement | null;
  const genreDropdownEl = root.querySelector(
    "[data-genre-dropdown]"
  ) as HTMLDetailsElement | null;
  const genreSelectAllBtn = root.querySelector(
    "[data-genre-select-all]"
  ) as HTMLButtonElement | null;
  const genreDeselectAllBtn = root.querySelector(
    "[data-genre-deselect-all]"
  ) as HTMLButtonElement | null;
  const subtitleEl = document.querySelector("[data-subtitle]") as HTMLElement | null;
  const posterModal = document.createElement("div");
  posterModal.className = "poster-modal";
  posterModal.hidden = true;
  posterModal.innerHTML = `
    <div class="poster-modal-backdrop" aria-hidden="true"></div>
    <div class="poster-modal-content" role="dialog" aria-modal="true">
      <img class="poster-modal-image" alt="" />
    </div>
  `;
  document.body.appendChild(posterModal);

  const posterModalImage = posterModal.querySelector(
    ".poster-modal-image"
  ) as HTMLImageElement | null;

  const openPosterModal = (src: string, alt: string) => {
    if (!posterModalImage) return;
    posterModalImage.src = src;
    posterModalImage.alt = alt;
    posterModal.hidden = false;
  };

  const closePosterModal = () => {
    if (!posterModalImage) return;
    posterModal.hidden = true;
    posterModalImage.src = "";
    posterModalImage.alt = "";
  };

  posterModal.addEventListener("click", () => {
    closePosterModal();
  });

  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && !posterModal.hidden) {
      closePosterModal();
    }
  });

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseKey = import.meta.env.PUBLIC_SUPABASE_PUBLISHABLE_KEY;

  type ScreeningRow = {
    screening_time: string | null;
    cinema_name: string | null;
    movie_name_en: string | null;
    movie_version: string | null;
    screening_date: string | null;
    poster_path: string | null;
    overview_en: string | null;
    movie_length: number | null;
    release_date: string | null;
    movie_name_raw: string | null;
    genres?: string | null;
    orig_language?: string | null;
    orig_country?: string | null;
    cinema_link?: string | null;
    tmdb_id?: number | null;
    tagline_en?: string | null;
  };

  let allRows: ScreeningRow[] = [];
  let allCinemas: string[] = [];
  let allMovies: string[] = [];
  let allGenres: string[] = [];
  let selectedCinemas = new Set<string>();
  let selectedMovies = new Set<string>();
  let selectedGenres = new Set<string>();
  let includePast: "yes" | "no" = "no";
  let screeningDate: string | null = null;
  let movieSearchQuery = "";

  const setStatus = (text: string) => {
    if (statusEl) {
      statusEl.textContent = text;
    }
  };

  const showTable = () => {
    if (tableWrap) {
      tableWrap.hidden = false;
    }
  };

  const showControls = () => {
    if (controlsEl) {
      controlsEl.hidden = false;
    }
  };

  const clearRows = () => {
    if (rowsEl) {
      rowsEl.innerHTML = "";
    }
  };

  const formatTime = (value: string | null | undefined) => {
    if (!value) return "";
    const match = value.match(/(\d{1,2}):(\d{2})/);
    if (match) {
      const hours = String(match[1]).padStart(2, "0");
      const minutes = match[2];
      return `${hours}:${minutes}`;
    }

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return value;
    const hours = String(date.getHours()).padStart(2, "0");
    const minutes = String(date.getMinutes()).padStart(2, "0");
    return `${hours}:${minutes}`;
  };

  const timeToMinutes = (value: string | null | undefined) => {
    if (!value) return null;
    const match = value.match(/(\d{1,2}):(\d{2})/);
    if (match) {
      const hours = Number.parseInt(match[1], 10);
      const minutes = Number.parseInt(match[2], 10);
      if (!Number.isNaN(hours) && !Number.isNaN(minutes)) {
        return hours * 60 + minutes;
      }
    }

    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return null;
    return date.getHours() * 60 + date.getMinutes();
  };

  const getTaipeiMinutes = () => {
    const now = new Date();
    const formatter = new Intl.DateTimeFormat("en-GB", {
      timeZone: "Asia/Taipei",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false
    });
    const parts = formatter.formatToParts(now);
    const hourPart = parts.find((part) => part.type === "hour");
    const minutePart = parts.find((part) => part.type === "minute");
    const hours = hourPart ? Number.parseInt(hourPart.value, 10) : now.getHours();
    const minutes = minutePart
      ? Number.parseInt(minutePart.value, 10)
      : now.getMinutes();
    if (Number.isNaN(hours) || Number.isNaN(minutes)) {
      return now.getHours() * 60 + now.getMinutes();
    }
    return hours * 60 + minutes;
  };

  const updateSubtitle = () => {
    if (!subtitleEl || !screeningDate) return;
    subtitleEl.textContent = `Showing results for today - ${screeningDate}`;
  };

  const renderRows = (rows: ScreeningRow[]) => {
    clearRows();
    if (!rowsEl) return;

    rows.forEach((row, index) => {
      const movieName = row.movie_name_en?.trim() ?? "";
      const movieVersion = row.movie_version?.trim() ?? "";
      const movieLabel = movieName
        ? movieVersion
          ? `${movieName} (${movieVersion})`
          : movieName
        : "";
      const tagline = row.tagline_en?.trim() ?? "";
      const overview = row.overview_en?.trim() ?? "";
      const rawGenres = row.genres?.trim() ?? "";
      const genreList = rawGenres
        .split(",")
        .map((genre: string) => genre.trim())
        .filter(Boolean);
      const genresLabel = genreList.length === 1 ? "Genre" : "Genres";
      const genresText = genreList.join(", ");
      const origLanguage = row.orig_language?.trim() ?? "";
      const rawCountries = row.orig_country?.trim() ?? "";
      const countryList = rawCountries
        .split(",")
        .map((country: string) => country.trim())
        .filter(Boolean);
      const countryLabel = countryList.length === 1 ? "Original country" : "Original countries";
      const countryText = countryList.join(", ");
      const movieLength =
        row.movie_length === null || row.movie_length === undefined
          ? ""
          : String(row.movie_length);
      const releaseDate = row.release_date?.trim() ?? "";
      const movieNameRaw = row.movie_name_raw?.trim() ?? "";
      const cinemaLink = row.cinema_link?.trim() ?? "";
      const tmdbId =
        row.tmdb_id === null || row.tmdb_id === undefined ? "" : String(row.tmdb_id);
      const tmdbLink = tmdbId ? `https://www.themoviedb.org/movie/${tmdbId}` : "";
      const posterPath = row.poster_path?.trim() ?? "";
      const posterUrl = posterPath ? `https://image.tmdb.org/t/p/w185${posterPath}` : "";
      const posterFullUrl = posterPath
        ? `https://image.tmdb.org/t/p/w500${posterPath}`
        : "";
      const detailsParts: string[] = [];

      const tmdbLinkInline =
        tmdbLink && tagline
          ? `<span class="details-links-inline"><a class="details-link" href="${tmdbLink}" target="_blank" rel="noopener noreferrer">TMDB link</a></span>`
          : "";

      if (tagline) {
        detailsParts.push(
          `<p class="details-tagline"><em>${tagline}</em>${tmdbLinkInline ? ` ${tmdbLinkInline}` : ""}</p>`
        );
      }
      if (overview) {
        detailsParts.push(`<p class="details-overview">${overview}</p>`);
      }
      if (genresText) {
        detailsParts.push(
          `<p class="details-line">${genresLabel}: ${genresText}</p>`
        );
      }
      if (origLanguage || countryText || movieLength || releaseDate) {
        const metaRows: string[] = [];
        if (origLanguage || countryText) {
          metaRows.push(`
            <div class="details-meta-row">
              ${
                origLanguage
                  ? `<span class="details-meta-item">Original language: ${origLanguage}</span>`
                  : ""
              }
              ${
                countryText
                  ? `<span class="details-meta-item">${countryLabel}: ${countryText}</span>`
                  : ""
              }
            </div>
          `);
        }
        if (movieLength || releaseDate) {
          metaRows.push(`
            <div class="details-meta-row">
              ${
                movieLength
                  ? `<span class="details-meta-item">Movie length: ${movieLength} minutes</span>`
                  : ""
              }
              ${
                releaseDate
                  ? `<span class="details-meta-item">Release date: ${releaseDate}</span>`
                  : ""
              }
            </div>
          `);
        }
        detailsParts.push(`<div class="details-meta">${metaRows.join("")}</div>`);
      }
      const linkParts: string[] = [];
      if (cinemaLink) {
        linkParts.push(
          `<a class="details-link" href="${cinemaLink}" target="_blank" rel="noopener noreferrer">Cinema link</a>`
        );
      }
      if (tmdbLink && !tagline) {
        linkParts.push(
          `<a class="details-link" href="${tmdbLink}" target="_blank" rel="noopener noreferrer">TMDB link</a>`
        );
      }
      const linksInline = linkParts.length
        ? `<span class="details-links-inline">${linkParts.join("")}</span>`
        : "";

      if (movieNameRaw) {
        detailsParts.push(
          `<p class="details-line">You will find this movie in the cinema as <span class="details-highlight">${movieNameRaw}</span>.${linksInline ? ` ${linksInline}` : ""}</p>`
        );
      } else if (linksInline) {
        detailsParts.push(`<p class="details-line">${linksInline}</p>`);
      }

      const mainRow = document.createElement("tr");
      const detailsRow = document.createElement("tr");
      const detailsId = `details-${index}`;

      mainRow.className = `movie-row ${index % 2 === 0 ? "is-odd" : "is-even"}`;
      mainRow.setAttribute("role", "button");
      mainRow.setAttribute("tabindex", "0");
      mainRow.setAttribute("aria-expanded", "false");
      mainRow.setAttribute("aria-controls", detailsId);
      mainRow.innerHTML = `
        <td>${formatTime(row.screening_time)}</td>
        <td>${row.cinema_name ?? ""}</td>
        <td>
          <div class="movie-cell">
            <span class="movie-title">${movieLabel}</span>
            <span class="movie-caret" aria-hidden="true"></span>
          </div>
        </td>
      `;

      detailsRow.id = detailsId;
      detailsRow.className = "details-row";
      detailsRow.hidden = true;
      detailsRow.innerHTML = `
        <td colspan="3">
          <div class="details-panel">
            <div class="details-grid${posterUrl ? "" : " no-poster"}">
              ${
                posterUrl
                  ? `<div class="details-poster">
                      <img src="${posterUrl}" alt="Poster for ${
                        movieLabel || movieNameRaw || "movie"
                      }" loading="lazy" data-full-src="${posterFullUrl}" />
                    </div>`
                  : ""
              }
              <div class="details-content">
                ${detailsParts.join("")}
              </div>
            </div>
          </div>
        </td>
      `;

      const toggleDetails = () => {
        const isOpen = mainRow.classList.toggle("is-open");
        mainRow.setAttribute("aria-expanded", String(isOpen));
        detailsRow.hidden = !isOpen;
      };

      mainRow.addEventListener("click", () => {
        toggleDetails();
      });

      mainRow.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          toggleDetails();
        }
      });

      rowsEl.appendChild(mainRow);
      rowsEl.appendChild(detailsRow);

      const posterImage = detailsRow.querySelector(
        ".details-poster img"
      ) as HTMLImageElement | null;
      if (posterImage && posterFullUrl) {
        posterImage.addEventListener("click", (event) => {
          event.stopPropagation();
          openPosterModal(
            posterFullUrl,
            posterImage.alt || "Movie poster"
          );
        });
      }
    });
  };

  const updateSummary = () => {
    if (!cinemaSummaryEl) return;
    if (selectedCinemas.size === 0) {
      cinemaSummaryEl.textContent = "No cinemas selected";
      return;
    }

    if (selectedCinemas.size === allCinemas.length) {
      cinemaSummaryEl.textContent = "All cinemas";
      return;
    }

    const list = allCinemas.filter((cinema) => selectedCinemas.has(cinema));
    cinemaSummaryEl.textContent = `${list.length} selected`;
  };

  const updateMovieSummary = () => {
    if (!movieSummaryEl) return;
    if (selectedMovies.size === 0) {
      movieSummaryEl.textContent = "No movies selected";
      return;
    }

    if (selectedMovies.size === allMovies.length) {
      movieSummaryEl.textContent = "All movies";
      return;
    }

    const list = allMovies.filter((movie) => selectedMovies.has(movie));
    movieSummaryEl.textContent = `${list.length} selected`;
  };

  const renderCinemaOptions = () => {
    if (!cinemaOptionsEl) return;
    cinemaOptionsEl.innerHTML = "";

    allCinemas.forEach((cinema) => {
      const option = document.createElement("label");
      option.className = "multi-select-option";
      const checkbox = document.createElement("input");
      checkbox.type = "checkbox";
      checkbox.value = cinema;
      checkbox.checked = selectedCinemas.has(cinema);
      checkbox.addEventListener("change", () => {
        if (checkbox.checked) {
          selectedCinemas.add(cinema);
        } else {
          selectedCinemas.delete(cinema);
        }
        updateSummary();
        applyFilters();
      });

      const span = document.createElement("span");
      span.textContent = ` ${cinema}`;
      option.appendChild(checkbox);
      option.appendChild(span);
      cinemaOptionsEl.appendChild(option);
    });
  };

  const updateGenreSummary = () => {
    if (!genreSummaryEl) return;
    if (selectedGenres.size === 0) {
      genreSummaryEl.textContent = "No genres selected";
      return;
    }

    if (selectedGenres.size === allGenres.length) {
      genreSummaryEl.textContent = "All genres";
      return;
    }

    const list = allGenres.filter((genre) => selectedGenres.has(genre));
    genreSummaryEl.textContent = `${list.length} selected`;
  };

  const renderMovieOptions = () => {
    if (!movieOptionsEl) return;
    movieOptionsEl.innerHTML = "";

    const filteredMovies = movieSearchQuery
      ? allMovies.filter((movie) =>
          movie.toLowerCase().includes(movieSearchQuery)
        )
      : allMovies;

    filteredMovies.forEach((movie) => {
      const option = document.createElement("label");
      option.className = "multi-select-option";
      const checkbox = document.createElement("input");
      checkbox.type = "checkbox";
      checkbox.value = movie;
      checkbox.checked = selectedMovies.has(movie);
      checkbox.addEventListener("change", () => {
        if (checkbox.checked) {
          selectedMovies.add(movie);
        } else {
          selectedMovies.delete(movie);
        }
        updateMovieSummary();
        applyFilters();
      });

      const span = document.createElement("span");
      span.textContent = ` ${movie}`;
      option.appendChild(checkbox);
      option.appendChild(span);
      movieOptionsEl.appendChild(option);
    });
  };

  const renderGenreOptions = () => {
    if (!genreOptionsEl) return;
    genreOptionsEl.innerHTML = "";

    allGenres.forEach((genre) => {
      const option = document.createElement("label");
      option.className = "multi-select-option";
      const checkbox = document.createElement("input");
      checkbox.type = "checkbox";
      checkbox.value = genre;
      checkbox.checked = selectedGenres.has(genre);
      checkbox.addEventListener("change", () => {
        if (checkbox.checked) {
          selectedGenres.add(genre);
        } else {
          selectedGenres.delete(genre);
        }
        updateGenreSummary();
        applyFilters();
      });

      const span = document.createElement("span");
      span.textContent = ` ${genre}`;
      option.appendChild(checkbox);
      option.appendChild(span);
      genreOptionsEl.appendChild(option);
    });
  };

  const applyFilters = () => {
    if (!allRows.length) {
      setStatus("No screenings yet.");
      return;
    }

    const filtered = allRows.filter((row) => {
      const cinema = row.cinema_name ?? "";
      const matchesCinema = selectedCinemas.has(cinema);
      if (!matchesCinema) return false;
      const movieName = row.movie_name_en?.trim() ?? "";
      if (movieName) {
        const matchesMovie = selectedMovies.has(movieName);
        if (!matchesMovie) return false;
      }
      const rowGenres = (row.genres ?? "")
        .split(",")
        .map((genre) => genre.trim())
        .filter(Boolean);
      if (rowGenres.length > 0) {
        const matchesGenre = rowGenres.some((genre) => selectedGenres.has(genre));
        if (!matchesGenre) return false;
      } else if (!selectedGenres.has("Genre unknown")) {
        return false;
      }
      if (includePast === "yes") return true;
      const rowMinutes = timeToMinutes(row.screening_time);
      if (rowMinutes === null) return false;
      return rowMinutes >= getTaipeiMinutes();
    });

    const sorted = [...filtered].sort((a, b) => {
      const aMinutes = timeToMinutes(a.screening_time) ?? 0;
      const bMinutes = timeToMinutes(b.screening_time) ?? 0;
      return aMinutes - bMinutes;
    });

    if (sorted.length === 0) {
      setStatus("No results - change the filters above");
    } else {
      setStatus("");
    }

    renderRows(sorted);
    showTable();
  };

  const load = async () => {
    if (!supabaseUrl || !supabaseKey) {
      setStatus("Missing Supabase public environment variables.");
      return;
    }

    const supabase = createClient(supabaseUrl, supabaseKey);

  const { data, error } = await supabase.from("screenings_serve").select("*");

    if (error) {
      setStatus(`Could not load screenings (${error.code ?? "unknown"}).`);
      console.error("Supabase error:", error);
      return;
    }

    if (!data || data.length === 0) {
      setStatus("No screenings yet.");
      return;
    }

    allRows = data;
    screeningDate = data.find((row) => row.screening_date)?.screening_date ?? null;
    allCinemas = Array.from(
      new Set(
        data
          .map((row) => row.cinema_name)
          .filter((cinema): cinema is string => Boolean(cinema && cinema.trim()))
      )
    ).sort((a, b) => a.localeCompare(b));

    allMovies = Array.from(
      new Set(
        data
          .map((row) => row.movie_name_en)
          .filter((movie): movie is string => Boolean(movie && movie.trim()))
          .map((movie) => movie.trim())
      )
    ).sort((a, b) => a.localeCompare(b));

    allGenres = Array.from(
      new Set(
        data
          .flatMap((row) =>
            (row.genres ?? "")
              .split(",")
              .map((genre: string) => genre.trim())
              .filter(Boolean)
          )
      )
    )
      .sort((a, b) => a.localeCompare(b))
      .concat("Genre unknown");

    selectedCinemas = new Set(allCinemas);
    selectedMovies = new Set(allMovies);
    selectedGenres = new Set(allGenres);

    renderCinemaOptions();
    updateSummary();
    renderMovieOptions();
    updateMovieSummary();
    renderGenreOptions();
    updateGenreSummary();
    updateSubtitle();
    showControls();
    applyFilters();
  };

  if (includePastEl) {
    includePastEl.addEventListener("change", () => {
      includePast = includePastEl.value === "no" ? "no" : "yes";
      applyFilters();
    });
  }

  if (selectAllBtn) {
    selectAllBtn.addEventListener("click", () => {
      selectedCinemas = new Set(allCinemas);
      renderCinemaOptions();
      updateSummary();
      applyFilters();
    });
  }

  if (deselectAllBtn) {
    deselectAllBtn.addEventListener("click", () => {
      selectedCinemas = new Set();
      renderCinemaOptions();
      updateSummary();
      applyFilters();
    });
  }

  if (movieSelectAllBtn) {
    movieSelectAllBtn.addEventListener("click", () => {
      selectedMovies = new Set(allMovies);
      renderMovieOptions();
      updateMovieSummary();
      applyFilters();
    });
  }

  if (movieDeselectAllBtn) {
    movieDeselectAllBtn.addEventListener("click", () => {
      selectedMovies = new Set();
      renderMovieOptions();
      updateMovieSummary();
      applyFilters();
    });
  }

  if (genreSelectAllBtn) {
    genreSelectAllBtn.addEventListener("click", () => {
      selectedGenres = new Set(allGenres);
      renderGenreOptions();
      updateGenreSummary();
      applyFilters();
    });
  }

  if (genreDeselectAllBtn) {
    genreDeselectAllBtn.addEventListener("click", () => {
      selectedGenres = new Set();
      renderGenreOptions();
      updateGenreSummary();
      applyFilters();
    });
  }

  if (movieSearchEl) {
    movieSearchEl.addEventListener("input", () => {
      movieSearchQuery = movieSearchEl.value.trim().toLowerCase();
      renderMovieOptions();
    });
  }

  if (cinemaDropdownEl) {
    document.addEventListener("click", (event) => {
      if (!cinemaDropdownEl.open) return;
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (!cinemaDropdownEl.contains(target)) {
        cinemaDropdownEl.open = false;
      }
    });
  }

  if (movieDropdownEl) {
    document.addEventListener("click", (event) => {
      if (!movieDropdownEl.open) return;
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (!movieDropdownEl.contains(target)) {
        movieDropdownEl.open = false;
      }
    });
  }

  if (genreDropdownEl) {
    document.addEventListener("click", (event) => {
      if (!genreDropdownEl.open) return;
      const target = event.target;
      if (!(target instanceof Node)) return;
      if (!genreDropdownEl.contains(target)) {
        genreDropdownEl.open = false;
      }
    });
  }

  load();
</script>

